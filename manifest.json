{
  "manifest_version": 3,
  "name": "Tab Agent",
  "version": "0.1.0",
  "description": "AI-powered tab grouping using Gemini Nano. No API key required.",

  "permissions": [
    "tabs",
    "storage"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Agent"
  }
}
