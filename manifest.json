{
  "manifest_version": 3,
  "name": "Tab Agent",
  "version": "0.2.0",
  "description": "Local-first browser tab memory agent that groups tabs, sleeps low-need tabs, wakes contexts, and learns from feedback.",

  "permissions": [
    "tabs",
    "storage",
    "processes",
    "alarms"
  ],
  "host_permissions": [
    "https://tabagentweb-on16.vercel.app/*",
    "https://tab-agent-web.vercel.app/*"
  ],

  "web_accessible_resources": [
    {
      "resources": ["stats.html", "stats.js", "storage.js", "agent.js"],
      "matches": ["<all_urls>"]
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Agent"
  }
}
